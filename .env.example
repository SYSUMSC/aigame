# 根目录统一环境变量
# 推荐工作流：
# 1. `cp .env.example .env`
# 2. 只改这一份 `.env`
# 3. Docker Compose、WebApp 本地脚本、EvaluateApp 本地运行都优先复用它

# -------------------- 共享基础配置 --------------------
TZ=Asia/Shanghai
PUBLIC_HOST=localhost

# MongoDB（Compose 共享）
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=password
MONGODB_REPLICA_SET=rs0
MONGO_HOST_PORT=37017

# Redis（Compose 共享）
REDIS_PASSWORD=password
REDIS_HOST_PORT=36379

# MinIO（Compose 共享）
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=password
MINIO_API_HOST_PORT=39000
MINIO_CONSOLE_HOST_PORT=39001

# 应用对外端口（Compose 共享）
WEBAPP_HOST_PORT=33000
EVALUATEAPP_HOST_PORT=38000

# -------------------- WebApp / 通用业务配置 --------------------
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
NEXTAUTH_SECRET=your-nextauth-secret-key
EVALUATION_TIMEOUT_MS=900000
# 反向代理为 HTTPS 时可显式强制 Secure Cookie；留空则按请求头自动判断
# AUTH_COOKIE_SECURE=true

# WebApp -> EvaluateApp 的统一密钥
# 推荐让下面三项保持一致，降低配置复杂度。
SHARED_SECRET=a-very-long-and-random-shared-secret
EVALUATE_APP_SECRET=a-very-long-and-random-shared-secret
EVALUATE_APP_UPLOAD_SECRET=a-very-long-and-random-shared-secret

# SMTP（本地开发可开启 STUB）
SMTP_STUB=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME="AI Game Platform"
SMTP_SECURE=false
SMTP_TLS=true

# -------------------- EvaluateApp --------------------
# EvaluateApp 默认优先读取根目录 `.env`，并自动推导 WEBAPP_CALLBACK_URL。
# 注意：`docker-compose.yml`、`docker-compose.deploy.yml` 和 E2E 会显式覆盖为 `SANDBOX_BACKEND=DOCKER` + `DOCKER_IMAGE=self`。
# 这里的设置主要影响“你在宿主机直接运行 EvaluateApp”时的默认行为。
ENABLE_GRADIO=false
GRADIO_PATH=/gradio
ENABLE_SECCOMP=false
SANDBOX_BACKEND=CHROOT
DOCKER_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/python:3.12-slim-bookworm
DOCKER_PULL=false
DOCKER_MEMORY=2g
DOCKER_CPUS=1.0
DOCKER_NETWORK_MODE=none
# DOCKER_USER=65534:65534
DOCKER_SELF_BUILD_ON_HOST=true
DOCKER_SELF_TAG=aigame-eval:self
DOCKER_SELF_CONTEXT=.
DOCKER_SELF_DOCKERFILE=evaluateapp/docker/evaluateapp.Dockerfile

# -------------------- 可选覆盖项 --------------------
# 如果你确实需要手动覆盖自动推导结果，可取消注释并修改以下变量。
# MONGODB_URI=mongodb://root:password@127.0.0.1:37017/aigame?authSource=admin&replicaSet=rs0&directConnection=true
# REDIS_URL=redis://127.0.0.1:36379
# MINIO_ENDPOINT=127.0.0.1
# MINIO_PORT=39000
# MINIO_ACCESS_KEY=root
# MINIO_SECRET_KEY=password
# MINIO_PUBLIC_URL=http://localhost:39000
# MINIO_INTERNAL_URL=http://127.0.0.1:39000
# WEBAPP_BASE_URL=http://localhost:33000
# AUTH_ORIGIN=http://localhost:33000
# NUXT_PUBLIC_BASE_URL=http://localhost:33000
# EVALUATE_APP_URL=http://localhost:38000
# WEBAPP_CALLBACK_URL=http://localhost:33000/api/submissions/callback
